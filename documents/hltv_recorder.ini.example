; KTP HLTV Recorder Configuration
; Copy this file to your server's configs/ directory as hltv_recorder.ini

; Enable/disable HLTV recording (1 = enabled, 0 = disabled)
hltv_enabled = 1

; HLTV API base URL (data server HTTP API)
hltv_api_url = http://74.91.112.242:8087

; HLTV API authentication key
; Must match the key configured in hltv-api.py on the data server
hltv_api_key = your-api-key-here

; HLTV server port
; Each game server should have a unique paired HLTV port
; Example mapping:
;   Game Server Atlanta 1 (27015) -> HLTV 27020
;   Game Server Atlanta 2 (27016) -> HLTV 27021
;   Game Server Atlanta 3 (27017) -> HLTV 27022
;   etc.
hltv_port = 27020

; Fleet-friendly alias (UPPERCASE) — drives the portal URL hint shown in
; match-start chat and the demo glob the renamer service produces.
; Must match the directory name under http://74.91.112.242/demos/<X>/.
; Mapping (added v1.7.0):
;   Atlanta:   ATL1..ATL5
;   Dallas:    DAL1..DAL5
;   Denver:    DEN1..DEN5
;   New York:  NY1..NY5
;   Chicago:   CHI1..CHI4   (CHI5 disabled)
hltv_friendly = ATL1

; (legacy; ignored in v1.7.0+ — recording is driven by HLTV cfg, not this plugin)
;hltv_stop_delay = 75
